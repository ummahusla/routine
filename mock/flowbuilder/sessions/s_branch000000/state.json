{
  "schemaVersion": 1,
  "nodes": [
    {
      "id": "inbox_input",
      "type": "input",
      "value": {
        "source": "gmail",
        "query": "in:inbox is:unread newer_than:1d",
        "count": 10,
        "date": "today"
      }
    },
    {
      "id": "severity_branch",
      "type": "branch",
      "cond": "email.from.endsWith('@enterprise.com') || /urgent|outage|p0/i.test(email.subject)"
    },
    {
      "id": "urgent_send",
      "type": "flow",
      "flow": "gmail/send-email",
      "params": {
        "to": "oncall@example.com",
        "subject": "[Escalation] Enterprise inquiry needs immediate response",
        "body": "<p>An enterprise customer email matched the urgency rule. Original subject: <b>${email.subject}</b>. From: ${email.from}.</p>",
        "content_type": "text/html"
      }
    },
    {
      "id": "routine_draft",
      "type": "flow",
      "flow": "gmail/create-draft-email",
      "params": {
        "to": "${email.from}",
        "subject": "Re: ${email.subject}",
        "body": "Hi there,\n\nThanks for reaching out — we've got your message and a teammate will follow up shortly.\n\nBest,\nSupport",
        "content_type": "text/plain"
      }
    },
    {
      "id": "merge_outcome",
      "type": "merge"
    },
    {
      "id": "response_output",
      "type": "output",
      "value": {
        "format": "response-plan",
        "destination": "agent"
      }
    }
  ],
  "edges": [
    {
      "from": "inbox_input",
      "to": "severity_branch"
    },
    {
      "from": "severity_branch",
      "to": "urgent_send"
    },
    {
      "from": "severity_branch",
      "to": "routine_draft"
    },
    {
      "from": "urgent_send",
      "to": "merge_outcome"
    },
    {
      "from": "routine_draft",
      "to": "merge_outcome"
    },
    {
      "from": "merge_outcome",
      "to": "response_output"
    }
  ]
}
