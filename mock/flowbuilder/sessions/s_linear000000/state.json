{
  "schemaVersion": 1,
  "nodes": [
    {
      "id": "input_repo",
      "type": "input",
      "value": {
        "owner": "ummahusla",
        "repo": "flow-build",
        "repository": "ummahusla/flow-build",
        "label": "flow-build repository"
      }
    },
    {
      "id": "list_top_committers",
      "type": "flow",
      "flow": "github/list-top-committers",
      "params": {
        "repository": "ummahusla/flow-build",
        "limit": 10
      }
    },
    {
      "id": "extract_contacts",
      "type": "flow",
      "flow": "github/extract-contributor-contacts",
      "params": {
        "repository": "ummahusla/flow-build",
        "username": "all",
        "limit": 100
      }
    },
    {
      "id": "digest_output",
      "type": "output",
      "value": {
        "format": "markdown",
        "destination": "chat"
      }
    }
  ],
  "edges": [
    {
      "from": "input_repo",
      "to": "list_top_committers"
    },
    {
      "from": "list_top_committers",
      "to": "extract_contacts"
    },
    {
      "from": "extract_contacts",
      "to": "digest_output"
    }
  ]
}
